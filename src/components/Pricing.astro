---
const plans = [
  {
    name: 'Free',
    price: '0',
    period: 'para siempre',
    description: 'Todo lo esencial para gestionar tu gimnasio sin costo.',
    features: [
      'Suscripciones ilimitadas',
      'Registro de ventas ilimitado',
      '10 productos activos',
      '70 clientes activos',
      'Métricas esenciales',
      '1 administrador + 2 entrenadores',
    ],
    highlight: false,
    comingSoon: false,
    isFree: true,
    cta: 'Empezar Gratis',
  },
  {
    name: 'Pro',
    price: '19',
    period: '/mes',
    description: 'Para gimnasios en crecimiento que necesitan más poder.',
    features: [
      'Todo lo de Free +',
      'Productos ilimitados',
      'Clientes ilimitados',
      '4 administradores + 10 entrenadores',
      'Notificaciones por email',
      'Engagement, cumpleaños y recordatorios',
      'Campañas de descuentos y promociones',
      'Reportes avanzados exportables a Excel',
      'Dashboard financiero',
    ],
    highlight: true,
    comingSoon: false,
    cta: 'Comenzar con Pro',
  },
  {
    name: 'Enterprise',
    price: '49',
    period: '/mes',
    description: 'Control total para operaciones avanzadas y cadenas.',
    features: [
      'Todo lo de Pro +',
      'Administradores y entrenadores ilimitados',
      'Integraciones con torniquetes',
      'Control de acceso por QR',
      'Notificaciones por WhatsApp',
      'Soporte prioritario dedicado',
    ],
    highlight: false,
    comingSoon: false,
    cta: 'Contactar Ventas',
  },
];
---

<section id="pricing" class="pricing-section">
  <div class="container">
    <div class="pricing-header">
      <div class="section-label">
        <i class='bx bx-purchase-tag'></i>
        Precios
      </div>
      <h2 class="section-title">Olvídate del cuaderno, moderniza tu gimnasio</h2>
      <p class="section-subtitle">
        Gratis para siempre. Sin tarjeta de crédito. Actualiza cuando lo necesites.
      </p>
    </div>

    <div class="pricing-grid grid grid-3">
      {plans.map((plan) => (
        <div class={`pricing-card card ${plan.highlight ? 'highlighted' : ''}`}>
          {plan.highlight && <div class="popular-badge">⭐ Más Popular</div>}
          {plan.isFree && <div class="free-badge">✨ Gratis por siempre</div>}
          <div class="plan-name">{plan.name}</div>
          <div class="plan-price">
            <span class="currency">$</span>
            <span class="amount">{plan.price}</span>
            <span class="period">{plan.period}</span>
          </div>
          <p class="plan-desc">{plan.description}</p>

          <ul class="plan-features">
            {plan.features.map((feat) => (
              <li>
                <i class='bx bx-check'></i>
                <span>{feat}</span>
              </li>
            ))}
          </ul>

          <a href="#cta" class={`btn ${plan.highlight ? 'btn-primary' : 'btn-secondary'} btn-plan`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>

  .pricing-section {
    background: var(--bg-body);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .pricing-header .section-subtitle {
    margin: 0 auto;
  }

  .pricing-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-card.highlighted {
    border-color: var(--text-primary);
    box-shadow: var(--shadow-lg), 0 0 30px rgba(255, 255, 255, 0.05);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .free-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .plan-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .plan-price {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
  }

  .currency {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .amount {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .period {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .plan-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .plan-features {
    list-style: none;
    margin-bottom: 2rem;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .plan-features li:last-child {
    border-bottom: none;
  }

  .plan-features li i {
    color: var(--text-primary);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .btn-plan {
    width: 100%;
    padding: 0.875rem;
    font-size: 0.9375rem;
  }
</style>
