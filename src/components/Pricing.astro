---
const API_URL = import.meta.env.PUBLIC_API_URL || 'https://app.atheneafit.com/api/plans/';

const fallbackPlans = [
  {
    name: 'Free',
    price: '0',
    currency: 'USD',
    period: 'para siempre',
    description: 'Todo lo esencial para gestionar tu gimnasio sin costo.',
    features: [
      { text: 'Suscripciones ilimitadas', included: true },
      { text: 'Registro de ventas ilimitado', included: true },
      { text: '10 productos activos', included: true },
      { text: '50 clientes activos', included: true },
      { text: 'Métricas esenciales', included: true },
      { text: '1 administrador', included: true },
      { text: 'Soporte básico (tiempo de respuesta estándar)', included: true },
    ],
    highlight: false,
    comingSoon: false,
    isFree: true,
    cta: 'Empezar Gratis',
  },
  {
    name: 'Pro',
    price: '19',
    currency: 'USD',
    period: '/mes',
    description: 'Para gimnasios en crecimiento que necesitan más poder.',
    features: [
      { text: 'Todo lo de Free +', included: true },
      { text: 'Productos ilimitados', included: true },
      { text: 'Clientes ilimitados', included: true },
      { text: '4 administradores + 10 entrenadores', included: true },
      { text: 'Notificaciones por email', included: true },
      { text: 'Engagement, cumpleaños y recordatorios', included: true },
      { text: 'Campañas de descuentos y promociones', included: true },
      { text: 'Reportes avanzados exportables a Excel', included: true },
      { text: 'Dashboard financiero', included: true },
      { text: 'Soporte prioritario (atención preferencial)', included: true },
    ],
    highlight: true,
    comingSoon: false,
    cta: 'Comenzar con Pro',
  },
  {
    name: 'Enterprise',
    price: '49',
    currency: 'USD',
    period: '/mes',
    description: 'Control total para operaciones avanzadas y cadenas.',
    features: [
      { text: 'Todo lo de Pro +', included: true },
      { text: 'Administradores y entrenadores ilimitados', included: true },
      { text: 'Integraciones con torniquetes', included: true },
      { text: 'Control de acceso por QR', included: true },
      { text: 'Notificaciones por WhatsApp', included: true },
      { text: 'Soporte VIP dedicado', included: true },
    ],
    highlight: false,
    comingSoon: false,
    cta: 'Contactar Ventas',
  },
];
---


<section id="pricing" class="pricing-section" data-api-url={API_URL}>
  <div class="container">
    <div class="pricing-header">
      <div class="section-label">
        <i class='bx bx-purchase-tag'></i>
        Precios
      </div>
      <h2 class="section-title">Olvídate del cuaderno, moderniza tu gimnasio</h2>
      <p class="section-subtitle">
        Gratis para siempre. Sin tarjeta de crédito. Actualiza cuando lo necesites.
      </p>

      <div class="pricing-notice">
        <div class="notice-icon">🎁</div>
        <p class="notice-text">
          <strong>Beneficio de inicio:</strong> Todas las cuentas nuevas comienzan con <strong>30 días de Plan Pro de cortesía</strong>. Al finalizar, puedes continuar usando el <strong>Plan Free gratis para siempre</strong>, sin cargos automáticos ni pérdida de datos.
        </p>
      </div>
    </div>

    <div class="pricing-grid grid grid-3">
      {fallbackPlans.map((plan) => (
        <div class={`pricing-card card ${plan.highlight ? 'highlighted' : ''}`}>
          {plan.highlight && <div class="popular-badge">⭐ Más Popular</div>}
          {plan.isFree && <div class="free-badge">✨ Gratis por siempre</div>}
          <div class="plan-name">{plan.name}</div>
          <div class="plan-price">
            <span class="currency">{plan.currency === 'EUR' ? '€' : '$'}</span>
            <span class="amount">{plan.price}</span>
            <span class="period">{plan.period}</span>
          </div>
          <p class="plan-desc">{plan.description}</p>

          <ul class="plan-features">
            {plan.features.map((feat) => (
              <li class={feat.included ? '' : 'not-included'}>
                <i class={feat.included ? 'bx bx-check' : 'bx bx-lock-alt'}></i>
                <span>{feat.text}</span>
              </li>
            ))}
          </ul>

          <a href="#cta" class={`btn ${plan.highlight ? 'btn-primary' : 'btn-secondary'} btn-plan`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>

  .pricing-section {
    background: var(--bg-body);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .pricing-header .section-subtitle {
    margin: 0 auto;
  }

  .pricing-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-card.highlighted {
    border-color: var(--text-primary);
    box-shadow: var(--shadow-lg), 0 0 30px rgba(255, 255, 255, 0.05);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .free-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .plan-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .plan-price {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
  }

  .currency {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .amount {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .period {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .plan-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .plan-features {
    list-style: none;
    margin-bottom: 2rem;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .plan-features li:last-child {
    border-bottom: none;
  }

  .plan-features li i {
    color: var(--text-primary);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .plan-features li.not-included {
    color: var(--text-muted);
    opacity: 0.65;
  }

  .plan-features li.not-included i {
    color: var(--text-muted);
  }

  .btn-plan {
    width: 100%;
    padding: 0.875rem;
    font-size: 0.9375rem;
  }

  .pricing-notice {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed var(--border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-lg);
    max-width: 680px;
    margin: 1.5rem auto 0 auto;
    text-align: left;
  }

  .notice-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .notice-text {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .notice-text strong {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr !important;
    }
    .pricing-notice {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1rem;
    }
  }
</style>

<script>
  // ---------------------------------------------------------------------------
  // Client-side plan hydration
  // Fetches the live plan catalog from the Django API on every page load so the
  // landing always reflects the current state in the DB (no rebuild needed).
  // If the fetch fails for any reason the static fallback cards stay visible.
  //
  // Supports regional pricing: sends ?country=XX from localStorage (set by
  // the navbar country selector) or lets Cloudflare resolve via CF-IPCountry.
  // ---------------------------------------------------------------------------

  const CURRENCY_SYMBOLS = { USD: '$', EUR: '€' };

  function getCurrencySymbol(code) {
    return CURRENCY_SYMBOLS[code] || code + ' ';
  }

  async function fetchAndRenderPlans() {
    const section = document.getElementById('pricing');
    const grid = section?.querySelector('.pricing-grid');
    if (!section || !grid) return;

    const apiUrl = section.dataset.apiUrl;
    if (!apiUrl) return;

    // Build URL with country param if saved
    const savedCountry = localStorage.getItem('athena_country');
    const url = new URL(apiUrl);
    if (savedCountry) {
      url.searchParams.set('country', savedCountry);
    }

    try {
      const res = await fetch(url.toString());
      if (!res.ok) return;

      const text = await res.text();
      // Only parse if the response looks like JSON (avoids HTML redirect pages)
      if (!text.trim().startsWith('{') && !text.trim().startsWith('[')) return;

      const data = JSON.parse(text);
      if (!data?.plans?.length) return;

      // If country was detected by the API and user hasn't picked one,
      // update the navbar flag to match
      if (data.country_detected && data.country && !savedCountry) {
        localStorage.setItem('athena_country', data.country);
        window.dispatchEvent(new CustomEvent('country-detected', {
          detail: { country: data.country }
        }));
      }

      // Map API response to the card shape
      const plans = data.plans.map((p) => {
        const isFree = !p.is_purchasable || p.price_monthly === 0;
        const planCurrency = p.currency || data.currency || 'USD';
        let cta = 'Comenzar';
        if (isFree) cta = 'Empezar Gratis';
        else if (p.name.toLowerCase().includes('pro')) cta = 'Comenzar con Pro';
        else if (
          p.name.toLowerCase().includes('enterprise') ||
          p.name.toLowerCase().includes('business')
        )
          cta = 'Contactar Ventas';
        else cta = `Comenzar con ${p.name}`;

        return {
          name: p.name,
          price: isFree ? '0' : Math.round(p.price_monthly).toString(),
          currencySymbol: getCurrencySymbol(planCurrency),
          period: isFree ? 'para siempre' : '/mes',
          description: p.tagline || '',
          features: p.features || [],
          highlight: p.is_recommended,
          isFree,
          cta,
        };
      });

      // ---- Animate the swap ----
      grid.style.transition = 'opacity 0.25s ease';
      grid.style.opacity = '0';
      await new Promise((r) => setTimeout(r, 260));

      // Adapt grid columns when plan count differs from fallback
      if (plans.length !== 3) {
        grid.style.gridTemplateColumns = `repeat(${Math.min(plans.length, 3)}, 1fr)`;
        if (plans.length < 3) {
          grid.style.maxWidth = `${plans.length * 420}px`;
          grid.style.marginInline = 'auto';
        }
      } else {
        grid.style.gridTemplateColumns = '';
        grid.style.maxWidth = '';
        grid.style.marginInline = '';
      }

      grid.innerHTML = plans
        .map(
          (plan) => `
        <div class="pricing-card card ${plan.highlight ? 'highlighted' : ''}">
          ${plan.highlight ? '<div class="popular-badge">⭐ Más Popular</div>' : ''}
          ${plan.isFree ? '<div class="free-badge">✨ Gratis por siempre</div>' : ''}
          <div class="plan-name">${plan.name}</div>
          <div class="plan-price">
            <span class="currency">${plan.currencySymbol}</span>
            <span class="amount">${plan.price}</span>
            <span class="period">${plan.period}</span>
          </div>
          <p class="plan-desc">${plan.description}</p>
          <ul class="plan-features">
            ${plan.features
              .map(
                (f) => `
              <li class="${f.included ? '' : 'not-included'}">
                <i class="${f.included ? 'bx bx-check' : 'bx bx-lock-alt'}"></i>
                <span>${f.text}</span>
              </li>`
              )
              .join('')}
          </ul>
          <a href="#cta" class="btn ${plan.highlight ? 'btn-primary' : 'btn-secondary'} btn-plan">
            ${plan.cta}
          </a>
        </div>`
        )
        .join('');

      // Fade in the fresh cards
      requestAnimationFrame(() => {
        grid.style.opacity = '1';
      });
    } catch (e) {
      // Silently keep the static fallback plans on any network/parsing error
      console.warn('[Pricing] Client-side fetch failed, keeping static plans:', e);
    }
  }

  // Initial fetch
  fetchAndRenderPlans();

  // Re-fetch when user changes country from the navbar selector
  window.addEventListener('country-changed', () => {
    fetchAndRenderPlans();
  });
</script>
