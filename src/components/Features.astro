---
const features = [
  {
    icon: 'bx-calendar-check',
    title: 'Suscripciones',
    description: 'Gestiona planes, controla vencimientos y automatiza renovaciones. Todo el ciclo de vida de tus membresías.',
    color: 'brand',
  },
  {
    icon: 'bx-group',
    title: 'Clientes',
    description: 'Registro completo con fotos, historial y seguimiento. Búsqueda avanzada y filtros inteligentes.',
    color: 'brand',
  },
  {
    icon: 'bx-credit-card',
    title: 'Pagos y Cobros',
    description: 'Registra pagos en efectivo, transferencia o tarjeta. Venta rápida y conciliación automática.',
    color: 'brand',
  },
  {
    icon: 'bx-line-chart',
    title: 'Dashboard en Tiempo Real',
    description: 'Métricas clave al instante: ingresos, gastos, crecimiento de miembros y análisis financiero.',
    color: 'brand',
  },
  {
    icon: 'bx-bell',
    title: 'Notificaciones',
    description: 'Alertas automáticas de vencimientos, recordatorios por email y notificaciones personalizables.',
    color: 'brand',
  },
  {
    icon: 'bx-shield-quarter',
    title: 'Control de Acceso',
    description: 'Roles y permisos granulares. Menú dinámico, multi-gimnasio y auditoría de accesos.',
    color: 'brand',
  },
];
---

<section id="features" class="features-section">
  <div class="container">
    <div class="features-header">
      <div class="section-label">
        <i class='bx bx-star'></i>
        Características
      </div>
      <h2 class="section-title">Todo lo que necesitas en un solo lugar</h2>
      <p class="section-subtitle">
        Herramientas potentes diseñadas específicamente para la gestión de gimnasios modernos.
      </p>
    </div>

    <div class="features-grid grid grid-3">
      {features.map((feature) => (
        <div class="feature-card card">
          <div class={`feature-icon ${feature.color}`}>
            <i class={`bx ${feature.icon}`}></i>
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-desc">{feature.description}</p>
          <div class="feature-link">
            <span>Saber más</span>
            <i class='bx bx-right-arrow-alt'></i>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    position: relative;
    background: var(--bg-body);
  }

  .features-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .features-header .section-subtitle {
    margin: 0 auto;
  }

  .feature-card {
    padding: 2rem;
    cursor: default;
  }

  .feature-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .feature-icon.brand { background: var(--accent-brand-dim); color: var(--text-primary); border: 1px solid var(--border); }
  .feature-icon.success { background: var(--accent-success-dim); color: var(--accent-success); }
  .feature-icon.info { background: var(--accent-info-dim); color: var(--accent-info); }
  .feature-icon.warning { background: var(--accent-warning-dim); color: var(--accent-warning); }
  .feature-icon.danger { background: var(--accent-danger-dim); color: var(--accent-danger); }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .feature-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    transition: gap 0.2s;
  }

  .feature-card:hover .feature-link {
    gap: 0.75rem;
  }
</style>
