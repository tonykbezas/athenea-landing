<script>
  const URLS = [
    'app.atheneafit.com/dashboard',
    'app.atheneafit.com/clientes',
    'app.atheneafit.com/suscripciones',
    'app.atheneafit.com/notificaciones',
  ];

  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  const tabs = document.querySelectorAll('.view-tab');
  const urlEl = document.getElementById('chrome-url');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    tabs[current].classList.remove('active');
    current = idx;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
    tabs[current].classList.add('active');
    if (urlEl) urlEl.textContent = URLS[current];
  }

  function startAuto() {
    timer = setInterval(() => goTo((current + 1) % slides.length), 4000);
  }

  function resetAuto() {
    clearInterval(timer);
    startAuto();
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      goTo(parseInt(tab.getAttribute('data-tab') || '0'));
      resetAuto();
    });
  });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.getAttribute('data-dot') || '0'));
      resetAuto();
    });
  });

  startAuto();
</script>

